cat > .gitignore << 'EOF'
# Dependencies
node_modules/
*/node_modules/

# Build outputs
dist/
build/
.next/
*/dist/
*/build/
*/.next/

# Environment files (NEVER commit these)
.env
.env.local
.env.*.local
*/.env
*/.env.local

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
EOF